generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Property {
  id                          String @id @default(cuid())
  name                        String
  legalName                   String
  address                     String @default("")
  city                        String
  country                     String
  phone                       String
  ice                         String
  logoUrl                     String @default("")
  defaultCurrency             String @default("MAD")
  touristTaxMadPerPersonNight Int    @default(30)
  vatRatePercent              Int    @default(10)
}

model Room {
  id       String  @id @default(cuid())
  name     String
  capacity Int
  rateMad  Int
  rateEur  Int
  rateUsd  Int
  active   Boolean @default(true)

  bookings Booking[]
  icalFeeds IcalFeed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guest {
  id             String  @id @default(cuid())
  fullName       String
  phone          String?
  email          String?
  nationality    String?
  documentNumber String?
  notes          String?

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id       String @id @default(cuid())
  guestId  String
  roomId   String
  guest    Guest  @relation(fields: [guestId], references: [id])
  room     Room   @relation(fields: [roomId], references: [id])

  checkIn  DateTime
  checkOut DateTime
  guests   Int      @default(1)
  source   String
  amount   Int
  currency String
  status   String
  notes    String?

  importedFromFeedId String?
  externalEventId    String?
  importedAt         DateTime?

  deletedAt DateTime?
  payments  Payment[]
  invoice   Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, checkIn, checkOut])
  @@index([guestId])
  @@unique([importedFromFeedId, externalEventId])
}

model Payment {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  amount      Int
  currency    String
  method      String
  paymentDate DateTime
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

model CashMovement {
  id       String   @id @default(cuid())
  date     DateTime
  type     String
  category String
  amount   Int
  currency String   @default("MAD")
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Invoice {
  id        String  @id
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  status      String
  finalNumber String? @unique
  finalizedAt DateTime?
  issueDate   DateTime
  total       Int
  currency    String
  lines       InvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int     @default(1)
  unitPrice   Int
  total       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
}

model IcalFeed {
  id           String    @id @default(cuid())
  name         String
  source       String
  url          String
  roomId       String?
  room         Room?     @relation(fields: [roomId], references: [id])
  active       Boolean   @default(true)
  lastSyncedAt DateTime?
  lastImportStatus  String?
  lastImportMessage String?
  lastImportImported Int @default(0)
  lastImportUpdated  Int @default(0)
  lastImportSkipped  Int @default(0)
  lastImportErrors   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
}
