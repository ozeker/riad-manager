DATABASE_URL="file:./prisma/dev.db"

# Used when switching to Supabase PostgreSQL.
# Keep local SQLite while testing, then replace DATABASE_URL during beta migration.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require"

OWNER_PASSWORD="change-this-owner-password"
AUTH_SECRET="change-this-to-a-long-random-secret"

# Reserved for future Supabase features. Not needed for the current MVP.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-side only. Do not expose this to the browser.
# SUPABASE_SERVICE_ROLE_KEY=""

